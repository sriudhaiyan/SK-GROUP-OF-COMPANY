rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
       return request.auth != null;
    }
    function isOwner(userId) {
       return isAuthenticated() && request.auth.uid == userId;
    }
    function uidUnchanged() {
       return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }
    function uidNotModified() {
       return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }
    function hasRequiredFields(fields) {
       return request.resource.data.keys().hasAll(fields);
    }
    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }
    
    // Domain Validators
    function isValidUser() {
      return hasOnlyAllowedFields(['uid', 'email', 'displayName', 'photoURL', 'rank', 'subscription', 'createdAt', 'lastLogin']);
    }

    function isValidUserCreate() {
      let data = request.resource.data;
      return isValidUser() && 
             data.uid is string && 
             data.email is string && 
             data.createdAt is timestamp && 
             data.lastLogin is timestamp;
    }

    function isValidUserUpdate() {
      let data = request.resource.data;
      return isValidUser() &&
             (!('uid' in data) || data.uid is string) &&
             (!('email' in data) || data.email is string) &&
             (!('createdAt' in data) || data.createdAt is timestamp) &&
             (!('lastLogin' in data) || data.lastLogin is timestamp);
    }
    
    function isValidChat() {
      return hasOnlyAllowedFields(['userId', 'characterId', 'userMessage', 'aiResponse', 'userImage', 'aiImage', 'timestamp']) &&
             request.resource.data.userId is string &&
             request.resource.data.characterId is string &&
             request.resource.data.userMessage is string &&
             request.resource.data.userMessage.size() < 10000 &&
             request.resource.data.aiResponse is string &&
             request.resource.data.aiResponse.size() < 10000 &&
             (!('userImage' in request.resource.data) || request.resource.data.userImage is string) &&
             (!('aiImage' in request.resource.data) || request.resource.data.aiImage is string) &&
             request.resource.data.timestamp is timestamp;
    }

    function isValidInquiry() {
      return hasOnlyAllowedFields(['userId', 'userEmail', 'name', 'email', 'message', 'source', 'timestamp']) &&
             request.resource.data.userId is string &&
             request.resource.data.name is string &&
             request.resource.data.name.size() < 200 &&
             request.resource.data.email is string &&
             request.resource.data.email.size() < 200 &&
             request.resource.data.message is string &&
             request.resource.data.message.size() < 5000 &&
             (!('source' in request.resource.data) || request.resource.data.source is string) &&
             (!('userEmail' in request.resource.data) || request.resource.data.userEmail is string) &&
             request.resource.data.timestamp is timestamp;
    }

    match /users/{userId} {
      allow read: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUserCreate() && uidUnchanged();
      allow update: if isOwner(userId) && isValidUserUpdate() && uidNotModified() && 
                    (!('createdAt' in request.resource.data) || request.resource.data.createdAt == resource.data.createdAt);
    }
    
    match /chats/{chatId} {
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidChat();
      allow update: if isAuthenticated() && resource.data.userId == request.auth.uid && isValidChat() &&
                    request.resource.data.userId == resource.data.userId &&
                    request.resource.data.timestamp == resource.data.timestamp;
    }

    match /inquiries/{inquiryId} {
      allow read: if false; // Only admin can read from console
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidInquiry();
      allow update, delete: if false;
    }
  }
}
